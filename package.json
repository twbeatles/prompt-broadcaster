{
  "name": "ai-prompt-broadcaster",
  "version": "1.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "node ./scripts/build.mjs --clean",
    "typecheck": "tsc --noEmit",
    "build": "node ./scripts/build.mjs",
    "rebuild": "npm run clean && npm run build",
    "qa:smoke": "node ./scripts/qa-smoke.mjs",
    "package:win": "powershell -ExecutionPolicy Bypass -File .\\package.ps1",
    "package:unix": "bash ./package.sh"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.24",
    "esbuild": "^0.25.2",
    "playwright": "^1.53.2",
    "typescript": "^5.8.3"
  }
}
